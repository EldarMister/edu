{
  "name": "edu-pos-backend",
  "version": "0.1.0",
  "description": "EDU POS backend (NestJS + Prisma + Socket.IO)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "prestart": "prisma migrate deploy",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "prestart:prod": "prisma migrate deploy",
    "start:prod": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "backup:prod": "ts-node --transpile-only scripts/backup-postgres-to-drive.ts",
    "popularity:recalculate": "ts-node --transpile-only scripts/recalculate-dish-popularity.ts",
    "drive:oauth:url": "ts-node --transpile-only scripts/google-drive-oauth.ts url",
    "drive:oauth:token": "ts-node --transpile-only scripts/google-drive-oauth.ts token",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/platform-socket.io": "^10.4.4",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^10.4.4",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "googleapis": "^173.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}
