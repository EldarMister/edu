// EDU POS Prisma schema
// Полная схема БД по ТЗ §13. На этапах 1–4 используются: User, Hall, Table,
// Category, Dish, Order, OrderItem, Payment, KitchenEvent.
// Остальные модели (Incident, PenaltyReward, AuditLog) заведены заранее
// для production-ready основы и будут задействованы на этапах 6–7.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  WAITER
  KITCHEN
  BAR
  ADMIN
  OWNER
}

// Направление приготовления/выдачи позиции: кухня или бар.
enum PrepStation {
  kitchen
  bar
  // «Без отправки» — официант забирает сам: позиция не уходит на кухню/бар.
  none
}

enum TableStatus {
  free // свободен
  occupied // занят
  sent_to_kitchen // заказ отправлен на кухню
  accepted // кухня приняла
  cooking // готовится
  ready // готов
  served // вынесен
  waiting_payment // ожидание оплаты
  paid // оплачен
}

enum OrderStatus {
  draft
  sent_to_kitchen
  accepted_by_kitchen
  cooking
  ready
  picked_up
  served
  waiting_payment
  paid
  rejected
  partially_rejected
  cancelled
}

enum OrderItemStatus {
  new
  accepted
  cooking
  ready
  rejected
  served
  cancelled
}

enum DiscountType {
  none
  percent
  fixed
}

enum PaymentMethod {
  qr
  cash
  card
  mixed // смешанная: часть наличными, часть QR (детали — в строках Payment)
}

enum PaymentStatus {
  pending
  paid
  refunded
  cancelled
}

enum PaymentSource {
  normal
  split
}

enum WaiterShiftStatus {
  active
  closed
}

enum KitchenEventType {
  accept
  reject_order
  reject_item
  ready_order
  ready_item
}

enum IncidentStatus {
  new
  in_progress
  closed
}

enum PenaltyType {
  penalty
  reward
}

enum ReceiptPrintStatus {
  pending // ожидает решения администратора
  approved // администратор подтвердил
  rejected // администратор отклонил
  printed // чек распечатан / отправлен на печать
}

enum ReceiptPrintType {
  receipt // обычный (финальный) чек
  preliminary // предварительный чек (предчек)
}

// ---------- Склад: сырьё / техкарты / закупки / движения ----------

enum StockMovementType {
  purchase // приход (закупка)
  sale // списание по техкарте при продаже
  return // возврат при отмене/отказе
  correction // ручная корректировка
  cancel // отмена операции
}

enum StockMovementSource {
  purchase // источник — закупка
  order // источник — заказ
  manual // ручная операция
}

enum PurchaseStatus {
  draft // черновик
  completed // проведена
  cancelled // отменена
}

// Тип единицы измерения сырья. База: mass→г, volume→мл, count→шт.
enum IngredientUnitType {
  mass // масса (г, кг)
  volume // объём (мл, л)
  count // штуки (шт)
}

// ---------- Models ----------

model User {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  login        String?  @unique
  passwordHash String   @map("password_hash")
  pinHash      String?  @map("pin_hash")
  role         Role
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders               Order[]               @relation("WaiterOrders")
  waiterShifts         WaiterShift[]         @relation("WaiterShifts")
  payments             Payment[]
  kitchenEvents        KitchenEvent[]
  penalties            PenaltyReward[]       @relation("PenaltyTarget")
  assignedRewards      PenaltyReward[]       @relation("PenaltyAuthor")
  incidentsOwned       Incident[]            @relation("IncidentUser")
  incidentsMade        Incident[]            @relation("IncidentAuthor")
  auditLogs            AuditLog[]
  pushSubscriptions    PushSubscription[]
  receiptPrintRequests ReceiptPrintRequest[] @relation("WaiterReceiptPrints")
  cashReports          ShiftCashReport[]     @relation("WaiterCashReports")

  @@map("users")
}

model Hall {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tables Table[]

  @@map("halls")
}

model Table {
  id        String      @id @default(uuid())
  hallId    String      @map("hall_id")
  number    Int
  seats     Int         @default(2)
  status    TableStatus @default(free)
  isActive  Boolean     @default(true) @map("is_active")
  sortOrder Int         @default(0) @map("sort_order")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  // Случайный неугадываемый токен для ссылки QR-меню стола (/menu/:qrToken).
  qrToken String @unique @default(uuid()) @map("qr_token")

  hall       Hall             @relation(fields: [hallId], references: [id], onDelete: Cascade)
  orders     Order[]
  incidents  Incident[]
  qrSessions QrTableSession[]

  @@unique([hallId, number])
  @@map("tables")
}

model Category {
  id          String      @id @default(uuid())
  name        String
  sortOrder   Int         @default(0) @map("sort_order")
  isActive    Boolean     @default(true) @map("is_active")
  prepStation PrepStation @default(kitchen) @map("prep_station")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  dishes Dish[]

  @@map("categories")
}

model Dish {
  id              String       @id @default(uuid())
  categoryId      String       @map("category_id")
  name            String
  description     String?
  price           Decimal      @db.Decimal(10, 2)
  imageUrl        String?      @map("image_url")
  discountType    DiscountType @default(none) @map("discount_type")
  discountValue   Decimal      @default(0) @map("discount_value") @db.Decimal(10, 2)
  cookingTime     Int?         @map("cooking_time") // минуты, опционально
  isAvailable     Boolean      @default(true) @map("is_available") // временно отключить
  isActive        Boolean      @default(true) @map("is_active")
  sortOrder       Int          @default(0) @map("sort_order")
  trackInventory  Boolean      @default(false) @map("track_inventory")
  stock           Int?
  initialStock    Int?         @map("initial_stock")
  unit            String       @default("шт")
  // null = наследовать направление от категории; задано — приоритет над категорией.
  prepStation     PrepStation? @map("prep_station")
  // true — это «шапка» сета (состав в SetComponent), а не обычное блюдо.
  isSet           Boolean      @default(false) @map("is_set")
  // Отдельное название для озвучки кухни (если задано — используется вместо name).
  voiceName       String?      @map("voice_name")
  popularityScore Float        @default(0) @map("popularity_score")
  scoreUpdatedAt  DateTime?    @map("score_updated_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  category           Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  variants           DishVariant[]
  // Состав сета (если это сет) и вхождения этого блюда в чужие сеты.
  setComponents      SetComponent[]          @relation("SetOf")
  inSetComponents    SetComponent[]          @relation("ComponentOf")
  // Снимки этого блюда в изменённых составах заказов.
  origOrderSetItems  OrderItemSetComponent[] @relation("OrigDish")
  finalOrderSetItems OrderItemSetComponent[] @relation("FinalDish")
  qrSessionItems     QrSessionItem[]
  // Техкарта блюда: какие ингредиенты и сколько уходит на 1 порцию.
  recipeItems        RecipeItem[]

  @@map("dishes")
}

model SetComponent {
  id            String   @id @default(uuid())
  setId         String   @map("set_id")
  dishId        String   @map("dish_id")
  // Вариант блюда в составе (например, «1 л»). null — блюдо без вариантов / базовое.
  dishVariantId String?  @map("dish_variant_id")
  quantity      Int      @default(1)
  sortOrder     Int      @default(0) @map("sort_order")
  removable     Boolean  @default(true)
  replaceable   Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  set         Dish         @relation("SetOf", fields: [setId], references: [id], onDelete: Cascade)
  dish        Dish         @relation("ComponentOf", fields: [dishId], references: [id], onDelete: Cascade)
  dishVariant DishVariant? @relation(fields: [dishVariantId], references: [id], onDelete: Cascade)

  @@index([setId])
  @@index([dishId])
  @@index([dishVariantId])
  @@map("set_components")
}

model DishVariant {
  id           String   @id @default(uuid())
  dishId       String   @map("dish_id")
  name         String
  price        Decimal  @db.Decimal(10, 2)
  sortOrder    Int      @default(0) @map("sort_order")
  stock        Int?
  initialStock Int?     @map("initial_stock")
  unit         String   @default("шт")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dish          Dish           @relation(fields: [dishId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  setComponents SetComponent[]

  @@index([dishId])
  @@map("dish_variants")
}

model Order {
  id                     String         @id @default(uuid())
  // Номер заказа сбрасывается каждый день (нумерация в пределах businessDate).
  orderNumber            String         @map("order_number")
  // Бизнес-день заказа (локальная полночь) — для дневной нумерации и уникальности номера в дне.
  businessDate           DateTime       @default(now()) @map("business_date")
  tableId                String         @map("table_id")
  // nullable: заказ из QR-меню создаётся без официанта (source=qr).
  waiterId               String?        @map("waiter_id")
  // Источник заказа: pos — создан сотрудником, qr — гостем через QR-меню.
  source                 String         @default("pos")
  waiterShiftId          String?        @map("waiter_shift_id")
  status                 OrderStatus    @default(draft)
  totalAmount            Decimal        @default(0) @map("total_amount") @db.Decimal(10, 2)
  discountAmount         Decimal        @default(0) @map("discount_amount") @db.Decimal(10, 2)
  serviceChargeAmount    Decimal        @default(0) @map("service_charge_amount") @db.Decimal(10, 2)
  finalAmount            Decimal        @default(0) @map("final_amount") @db.Decimal(10, 2)
  paymentStatus          PaymentStatus  @default(pending) @map("payment_status")
  paymentMethod          PaymentMethod? @map("payment_method")
  comment                String?
  requiresWaiterDecision Boolean        @default(false) @map("requires_waiter_decision")
  idempotencyKey         String?        @unique @map("idempotency_key")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  closedAt               DateTime?      @map("closed_at")

  // ККМ / фискализация (Кыргызстан). Заполняются при пробитии фискального чека через ККМ.
  // null = ККМ выключена или чек ещё не пробит. Хранятся на заказе: один фискальный чек на
  // оплаченный заказ (карточка заказа и кнопка «Повторить» работают per-order).
  fiscalReceiptNumber String?   @map("fiscal_receipt_number") // номер фискального чека
  fiscalSign          String?   @map("fiscal_sign") // фискальный признак
  fiscalQrCode        String?   @map("fiscal_qr_code") // QR ГНС для проверки чека
  fiscalError         String?   @map("fiscal_error") // текст ошибки ККМ (для бейджа и повтора)
  fiscalizedAt        DateTime? @map("fiscalized_at") // момент успешного пробития

  table                Table                 @relation(fields: [tableId], references: [id])
  waiter               User?                 @relation("WaiterOrders", fields: [waiterId], references: [id])
  waiterShift          WaiterShift?          @relation(fields: [waiterShiftId], references: [id])
  items                OrderItem[]
  payments             Payment[]
  kitchenEvents        KitchenEvent[]
  incidents            Incident[]
  actions              OrderAction[]
  receiptPrintRequests ReceiptPrintRequest[]
  // Заполняется, если заказ создан из QR-сессии стола.
  qrSession            QrTableSession?

  @@unique([businessDate, orderNumber])
  @@index([status])
  @@index([tableId])
  @@index([waiterId])
  @@index([waiterShiftId])
  @@map("orders")
}

model OrderAction {
  id             String   @id @default(uuid())
  orderId        String   @map("order_id")
  type           String
  idempotencyKey String   @map("idempotency_key")
  userId         String?  @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([type, idempotencyKey])
  @@index([orderId, type])
  @@map("order_actions")
}

model WaiterShift {
  id        String            @id @default(uuid())
  waiterId  String            @map("waiter_id")
  startedAt DateTime          @default(now()) @map("started_at")
  endedAt   DateTime?         @map("ended_at")
  status    WaiterShiftStatus @default(active)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  waiter User    @relation("WaiterShifts", fields: [waiterId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([waiterId, status])
  @@map("waiter_shifts")
}

// Факт сдачи наличных сотрудником за смену (на конкретную дату).
// «Касса (сдал)» в отчёте по сменам — вводится администратором, не расчётное.
model ShiftCashReport {
  id          String   @id @default(uuid())
  waiterId    String   @map("waiter_id")
  date        DateTime @db.Date
  cashHanded  Decimal  @default(0) @map("cash_handed") @db.Decimal(10, 2)
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  waiter User @relation("WaiterCashReports", fields: [waiterId], references: [id], onDelete: Cascade)

  @@unique([waiterId, date])
  @@map("shift_cash_reports")
}

model OrderItem {
  id                      String             @id @default(uuid())
  orderId                 String             @map("order_id")
  // nullable: блюдо может быть полностью удалено из меню — позиция остаётся в истории по снимкам.
  dishId                  String?            @map("dish_id")
  dishVariantId           String?            @map("dish_variant_id")
  dishNameSnapshot        String             @map("dish_name_snapshot")
  dishVariantNameSnapshot String?            @map("dish_variant_name_snapshot")
  // Снимок названия для озвучки (voiceName блюда на момент заказа).
  dishVoiceSnapshot       String?            @map("dish_voice_snapshot")
  priceSnapshot           Decimal            @map("price_snapshot") @db.Decimal(10, 2)
  quantity                Int                @default(1)
  discountAmount          Decimal            @default(0) @map("discount_amount") @db.Decimal(10, 2)
  finalPrice              Decimal            @map("final_price") @db.Decimal(10, 2)
  status                  OrderItemStatus    @default(new)
  prepStation             PrepStation        @default(kitchen) @map("prep_station")
  comment                 String?
  // «С собой» (навынос) — кухня видит, что позицию нужно упаковать.
  takeaway                Boolean            @default(false)
  rejectReason            String?            @map("reject_reason")
  rejectionDecision       RejectionDecision? @map("rejection_decision")
  replacementForItemId    String?            @map("replacement_for_item_id")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  order         Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish          Dish?                   @relation(fields: [dishId], references: [id], onDelete: SetNull)
  dishVariant   DishVariant?            @relation(fields: [dishVariantId], references: [id], onDelete: SetNull)
  // Состав сета с изменениями (если эта позиция — сет).
  setComponents OrderItemSetComponent[]

  @@index([orderId])
  @@index([dishVariantId])
  @@map("order_items")
}

enum SetComponentAction {
  default
  removed
  replaced
}

enum RejectionDecision {
  pending
  removed
  replaced
}

model OrderItemSetComponent {
  id                          String             @id @default(uuid())
  orderItemId                 String             @map("order_item_id")
  // nullable: блюдо состава может быть удалено из меню — имя сохраняется в снимке.
  originalDishId              String?            @map("original_dish_id")
  originalNameSnapshot        String             @map("original_name_snapshot")
  // Снимок названия варианта блюда состава (например, «1 л»), если он выбран.
  originalVariantNameSnapshot String?            @map("original_variant_name_snapshot")
  finalDishId                 String?            @map("final_dish_id")
  finalNameSnapshot           String?            @map("final_name_snapshot")
  action                      SetComponentAction @default(default)
  // Кухня отмечает каждое блюдо состава сета отдельно (как обычную позицию).
  status                      OrderItemStatus    @default(new)
  rejectReason                String?            @map("reject_reason")
  quantity                    Int                @default(1)
  sortOrder                   Int                @default(0) @map("sort_order")
  comment                     String?
  priceDelta                  Decimal            @default(0) @map("price_delta") @db.Decimal(10, 2)
  createdAt                   DateTime           @default(now()) @map("created_at")

  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  originalDish Dish?     @relation("OrigDish", fields: [originalDishId], references: [id], onDelete: SetNull)
  finalDish    Dish?     @relation("FinalDish", fields: [finalDishId], references: [id])

  @@index([orderItemId])
  @@map("order_item_set_components")
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @map("order_id")
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  source    PaymentSource @default(normal)
  status    PaymentStatus @default(paid)
  paidAt    DateTime      @default(now()) @map("paid_at")
  cashierId String        @map("cashier_id")

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cashier User  @relation(fields: [cashierId], references: [id])

  @@map("payments")
}

model KitchenEvent {
  id          String           @id @default(uuid())
  orderId     String           @map("order_id")
  orderItemId String?          @map("order_item_id")
  type        KitchenEventType
  reason      String?
  comment     String?
  createdById String           @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([orderId])
  @@map("kitchen_events")
}

model PenaltyReward {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  type        PenaltyType
  amount      Decimal     @db.Decimal(10, 2)
  reason      String
  createdById String      @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")

  user      User @relation("PenaltyTarget", fields: [userId], references: [id])
  createdBy User @relation("PenaltyAuthor", fields: [createdById], references: [id])

  @@map("staff_penalties_rewards")
}

model Incident {
  id           String         @id @default(uuid())
  type         String
  description  String?
  tableId      String?        @map("table_id")
  orderId      String?        @map("order_id")
  userId       String?        @map("user_id")
  damageAmount Decimal?       @map("damage_amount") @db.Decimal(10, 2)
  photoUrl     String?        @map("photo_url")
  status       IncidentStatus @default(new)
  createdById  String         @map("created_by")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  table     Table? @relation(fields: [tableId], references: [id])
  order     Order? @relation(fields: [orderId], references: [id])
  user      User?  @relation("IncidentUser", fields: [userId], references: [id])
  createdBy User   @relation("IncidentAuthor", fields: [createdById], references: [id])

  @@map("incidents")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  userName    String?  @map("user_name") // имя на момент действия (не зависит от переименования)
  userRole    String?  @map("user_role")
  actionType  String   @map("action_type")
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  tableId     String?  @map("table_id")
  orderId     String?  @map("order_id")
  description String?
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([actionType])
  @@index([userId])
  @@index([orderId])
  @@index([tableId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// Настройки заведения (singleton, id = "default"). Этап 8.
model Settings {
  id                           String  @id @default("default")
  cafeName                     String  @default("EDU CAFE") @map("cafe_name")
  address                      String  @default("г. Бишкек, ул. Киевская 120")
  phone                        String  @default("+996 500 123 456")
  phone2                       String  @default("+996 700 123 456")
  instagram                    String?
  website                      String?
  receiptText                  String  @default("Спасибо за покупку!") @map("receipt_text")
  serviceChargeAmount          Decimal @default(0) @map("service_charge_amount") @db.Decimal(10, 2)
  language                     String  @default("ru") // ru | ky
  payQr                        Boolean @default(true) @map("pay_qr")
  payCash                      Boolean @default(true) @map("pay_cash")
  payCard                      Boolean @default(true) @map("pay_card")
  qrImageUrl                   String? @map("qr_image_url") // data URL загруженного QR-кода (один на заведение)
  printerConnected             Boolean @default(false) @map("printer_connected")
  allowNegativeIngredientStock Boolean @default(true) @map("allow_negative_ingredient_stock")

  // QR-меню: опциональная гео-проверка присутствия гостя у кафе.
  // Владелец включает по желанию, делится координатами кафе и задаёт радиус.
  // Заказ блокируется, если гость дальше радиуса + буфер на погрешность GPS.
  qrGeoEnabled Boolean @default(false) @map("qr_geo_enabled")
  qrGeoLat     Float?  @map("qr_geo_lat")
  qrGeoLng     Float?  @map("qr_geo_lng")
  qrGeoRadius  Int     @default(150) @map("qr_geo_radius") // метры

  // ККМ / фискализация (Кыргызстан). Владелец выбирает провайдера и вводит ключи.
  // null/пусто в fiscalProvider = ККМ выключена, печать фискального чека недоступна.
  fiscalProvider      String? @map("fiscal_provider") // ekassa | yakassa | null
  fiscalEkassaApiKey  String? @map("fiscal_ekassa_api_key")
  fiscalEkassaUrl     String? @map("fiscal_ekassa_url") // базовый URL eKassa API (из документации)
  fiscalEkassaInn     String? @map("fiscal_ekassa_inn") // ИНН заведения
  fiscalYakassaApiKey String? @map("fiscal_yakassa_api_key")
  fiscalYakassaUrl    String? @map("fiscal_yakassa_url")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// Запрос официанта на печать чека — подтверждается администратором (раздел «Печать чека»).
model ReceiptPrintRequest {
  id          String             @id @default(uuid())
  orderId     String             @map("order_id")
  waiterId    String             @map("waiter_id")
  tableNumber Int                @map("table_number")
  orderNumber String             @map("order_number")
  amount      Decimal            @db.Decimal(10, 2)
  type        ReceiptPrintType   @default(receipt)
  status      ReceiptPrintStatus @default(pending)
  decidedById String?            @map("decided_by") // администратор, принявший решение
  createdAt   DateTime           @default(now()) @map("created_at")
  decidedAt   DateTime?          @map("decided_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  waiter User  @relation("WaiterReceiptPrints", fields: [waiterId], references: [id])

  @@index([status])
  @@index([waiterId])
  @@map("receipt_print_requests")
}

// ---------- QR-меню стола ----------
// Общий заказ стола, который гости наполняют со своих телефонов до отправки в POS.
// Черновик (draft) живёт до submit; после submit привязывается к реальному Order.

model QrTableSession {
  id               String   @id @default(uuid())
  tableId          String   @map("table_id")
  status           String   @default("draft") // draft | submitted | closed
  submittedOrderId String?  @unique @map("submitted_order_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  table          Table           @relation(fields: [tableId], references: [id], onDelete: Cascade)
  submittedOrder Order?          @relation(fields: [submittedOrderId], references: [id], onDelete: SetNull)
  guests         QrGuest[]
  items          QrSessionItem[]

  @@index([tableId, status])
  @@map("qr_table_sessions")
}

model QrGuest {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  // Секрет гостя из localStorage — идентифицирует устройство без авторизации.
  guestKey   String   @map("guest_key")
  guestLabel String   @map("guest_label") // «Гость 1», «Гость 2», …
  isOnline   Boolean  @default(true) @map("is_online")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  session QrTableSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items   QrSessionItem[]

  @@unique([sessionId, guestKey])
  @@index([sessionId])
  @@map("qr_guests")
}

model QrSessionItem {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  guestId        String   @map("guest_id")
  // nullable: блюдо может быть удалено из меню — отображение по снимку.
  dishId         String?  @map("dish_id")
  variantId      String?  @map("variant_id")
  quantity       Int      @default(1)
  snapshotName   String   @map("snapshot_name")
  variantName    String?  @map("variant_name")
  snapshotPrice  Decimal  @map("snapshot_price") @db.Decimal(10, 2)
  // Зарезервировано под добавки/модификаторы (в v1 не используется).
  selectedAddons Json?    @map("selected_addons")
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  session QrTableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  guest   QrGuest        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  dish    Dish?          @relation(fields: [dishId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([guestId])
  @@map("qr_session_items")
}

// ---------- Склад ----------

// Сырьё (ингредиент). Деньги — Decimal(12,2), количества — Decimal(12,3),
// чтобы хранить дробные граммы/килограммы (например, 0.120 кг).
model Ingredient {
  id                String             @id @default(uuid())
  name              String
  // Тип единицы и display-единица, выбранная админом (g|kg|ml|l|pcs).
  unitType          IngredientUnitType @default(count) @map("unit_type")
  displayUnit       String             @default("pcs") @map("display_unit")
  // ВНИМАНИЕ: stock/avgCost/lowStockThreshold хранятся в БАЗОВЫХ единицах (g|ml|pcs).
  stock             Decimal            @default(0) @db.Decimal(14, 3) // в базовых единицах
  avgCost           Decimal            @default(0) @map("avg_cost") @db.Decimal(20, 8) // себестоимость за базовую единицу
  lowStockThreshold Decimal            @default(0) @map("low_stock_threshold") @db.Decimal(14, 3) // база
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  recipeItems   RecipeItem[]
  purchaseItems PurchaseItem[]
  movements     StockMovement[]

  @@map("ingredients")
}

// Строка техкарты: сколько ингредиента уходит на 1 порцию блюда.
model RecipeItem {
  id           String   @id @default(uuid())
  dishId       String   @map("dish_id")
  ingredientId String   @map("ingredient_id")
  amount       Decimal  @db.Decimal(14, 3) // количество на 1 порцию в БАЗОВЫХ единицах
  amountUnit   String   @default("pcs") @map("amount_unit") // display-единица, выбранная при вводе
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dish       Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([dishId, ingredientId])
  @@index([dishId])
  @@index([ingredientId])
  @@map("recipe_items")
}

// Закупка. number — автоинкремент, на фронте показываем как «ЗКП-000142».
model Purchase {
  id          String         @id @default(uuid())
  number      Int            @default(autoincrement())
  date        DateTime       @default(now())
  supplier    String
  totalAmount Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  status      PurchaseStatus @default(draft)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  items PurchaseItem[]

  @@index([status])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchaseId    String   @map("purchase_id")
  ingredientId  String   @map("ingredient_id")
  // Введённые значения (в display-единице) — для отображения документа.
  unit          String   @default("pcs") // display-единица, выбранная при закупке
  quantity      Decimal  @db.Decimal(14, 3) // в display-единице
  purchasePrice Decimal  @map("purchase_price") @db.Decimal(20, 8) // цена за display-единицу
  total         Decimal  @db.Decimal(12, 2)
  // Конвертированные значения — основа остатков и себестоимости.
  quantityBase  Decimal  @default(0) @map("quantity_base") @db.Decimal(14, 3) // в базовых единицах
  unitPriceBase Decimal  @default(0) @map("unit_price_base") @db.Decimal(20, 8) // цена за базовую единицу
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  purchase   Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([purchaseId])
  @@index([ingredientId])
  @@map("purchase_items")
}

// Движение склада — неизменяемая запись в журнале остатков.
model StockMovement {
  id           String              @id @default(uuid())
  ingredientId String              @map("ingredient_id")
  orderItemId  String?             @map("order_item_id")
  type         StockMovementType
  sourceType   StockMovementSource @map("source_type")
  sourceId     String?             @map("source_id") // id закупки или заказа
  // Все количества — в БАЗОВЫХ единицах ингредиента (g|ml|pcs).
  beforeStock  Decimal             @map("before_stock") @db.Decimal(14, 3)
  change       Decimal             @db.Decimal(14, 3)
  afterStock   Decimal             @map("after_stock") @db.Decimal(14, 3)
  costAtMoment Decimal             @map("cost_at_moment") @db.Decimal(20, 8) // себестоимость за базовую единицу
  comment      String?
  createdAt    DateTime            @default(now()) @map("created_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([type, sourceType, sourceId, orderItemId, ingredientId], map: "stock_movements_order_item_once_key")
  @@index([ingredientId])
  @@index([orderItemId])
  @@index([createdAt])
  @@index([type])
  @@index([sourceType])
  @@map("stock_movements")
}
