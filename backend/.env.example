# --- Озвучка кухни (self-hosted Silero TTS, см. /tts-service) ---
# URL Python-сервиса Silero. Пусто = озвучка отключена (кухня работает без голоса,
# Web Speech НЕ включается). Пример локально: http://localhost:8001
TTS_SERVICE_URL=""
# Таймаут запроса к TTS (мс) и папка кэша готового аудио (по умолчанию — temp).
TTS_TIMEOUT_MS="15000"
# TTS_CACHE_DIR=""

# --- Status page мониторинг ---
