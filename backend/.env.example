# --- Database (ваша PostgreSQL) ---
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# --- JWT ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Server ---
PORT=3000
# CORS: адрес фронтенда (через запятую можно несколько)
CORS_ORIGIN="http://localhost:5173"

# --- Web Push уведомления ---
# Сгенерировать: npx web-push generate-vapid-keys
VAPID_SUBJECT="mailto:admin@example.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# --- Realtime (Redis adapter, опционально; пусто = single-instance) ---
REDIS_URL=""

# --- Озвучка кухни (self-hosted Silero TTS, см. /tts-service) ---
# URL Python-сервиса Silero. Пусто = озвучка отключена (кухня работает без голоса,
# Web Speech НЕ включается). Пример локально: http://localhost:8001
TTS_SERVICE_URL=""
# Таймаут запроса к TTS (мс) и папка кэша готового аудио (по умолчанию — temp).
TTS_TIMEOUT_MS="15000"
# TTS_CACHE_DIR=""

# --- Status page мониторинг ---
# Страница: /api/health/status
# Опционально: сравнение main/current базы с dev базой и показ коммита dev backend.
MONITOR_DEV_DATABASE_URL=""
MONITOR_DEV_HEALTH_URL=""

# --- Production DB backups to Google Drive ---
# Эти значения задаются в GitHub Actions Secrets/Variables, не в production .env.
BACKUP_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
GOOGLE_DRIVE_FOLDER_ID=""
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=""
BACKUP_RETENTION_DAYS="30"
BACKUP_PREFIX="edu-pos-prod"
BACKUP_PGSSLMODE="require"
BACKUP_ENCRYPTION_PASSWORD=""
BACKUP_FAILURE_WEBHOOK_URL=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
