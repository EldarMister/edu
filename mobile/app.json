{
  "expo": {
    "name": "EDU POS",
    "slug": "edu-pos-mobile",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "edupos",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#005BFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edupos.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.edupos.mobile",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "androidStatusBar": {
      "backgroundColor": "#005BFF",
      "barStyle": "light-content",
      "translucent": false
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#005BFF",
          "defaultChannel": "orders_v2",
          "sounds": [
            "./assets/sounds/notify.mp3",
            "./assets/sounds/new_order.mp3",
            "./assets/sounds/accept.mp3",
            "./assets/sounds/payment_sound.mp3"
          ]
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "e4170c03-bd0d-430d-b7e4-0fdf300c561f"
      }
    },
    "owner": "eldarchkk"
  }
}
